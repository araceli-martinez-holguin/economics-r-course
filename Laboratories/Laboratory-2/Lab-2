# SECCIÓN 8 — ANÁLISIS ADICIONAL: PRECIO REAL Y EFICIENCIA HISTÓRICA
# ==============================================================================
# BONUS para profundizar en el escenario T-MEC:
#   8A — Deflactar el PMR con inflación para comparar precios reales
#   8B — Índice de eficiencia acumulada (rendimiento vs superficie sembrada)
#   8C — Top 5 municipios productores por cultivo y año

# ------------------------------------------------------------------------------
# 8A — PMR REAL (deflactado)
# En 20 años la inflación distorsiona las comparaciones de precio.
# Usamos un deflactor simplificado basado en el año 2010 como base.
# En un análisis real se usaría el INPC del Banco de México.
# ------------------------------------------------------------------------------

# Factor de deflactación aproximado por año (base 2010 = 1.0)
# NOTA: en la práctica real, obtener del INPC BANXICO
deflactor <- tibble(
  Anio      = 2003:2024,
  def_2010  = c(0.681, 0.712, 0.739, 0.769, 0.795,
                0.847, 0.887, 1.000, 1.041, 1.065,
                1.105, 1.143, 1.178, 1.213, 1.249,
                1.290, 1.370, 1.480, 1.560, 1.640,
                1.820, 1.960)
)

pmr_real <- data %>%
  left_join(deflactor, by = "Anio") %>%
  mutate(PMR_real = PMR / def_2010) %>%   # precio en pesos constantes de 2010
  group_by(Nomcultivo, Anio) %>%
  summarise(
    pmr_real_prom    = mean(PMR_real, na.rm = TRUE),
    pmr_nominal_prom = mean(PMR,      na.rm = TRUE),
    .groups = "drop"
  )

# Comparar nominal vs real para cultivos estrella
pmr_real_plot <- pmr_real %>%
  filter(Nomcultivo %in% cultivos_estrella) %>%
  pivot_longer(cols      = c(pmr_real_prom, pmr_nominal_prom),
               names_to  = "tipo",
               values_to = "precio") %>%
  mutate(tipo = recode(tipo,
                       "pmr_real_prom"    = "Real (base 2010)",
                       "pmr_nominal_prom" = "Nominal")) %>%
  ggplot(aes(x = Anio, y = precio, color = tipo, group = tipo)) +
  geom_line(linewidth = 1) +
  geom_point(size = 1.8) +
  facet_wrap(~ Nomcultivo, scales = "free_y", ncol = 2) +
  scale_color_manual(values = c("Real (base 2010)" = "#2d6a4f",
                                "Nominal"           = "#e63946")) +
  labs(
    title    = "Precio Nominal vs Precio Real — Cultivos Estrella",
    subtitle = "Deflactado a pesos constantes de 2010",
    x        = "Año", y = "$/ton", color = NULL
  ) +
  theme_minimal(base_size = 11) +
  theme(legend.position = "bottom")

ggsave("pmr_real_vs_nominal.png", pmr_real_plot, dpi = 300, width = 14, height = 10)


# ------------------------------------------------------------------------------
# 8B — EFICIENCIA PRODUCTIVA: ¿los rendimientos mejoran con el tiempo?
# Calcular la tasa de cambio anual del rendimiento por cultivo (CAGR)
# ------------------------------------------------------------------------------

# CAGR = Compound Annual Growth Rate = (valor_final / valor_inicial)^(1/n) - 1
cagr_rendimiento <- data %>%
  group_by(Nomcultivo, Anio) %>%
  summarise(rend = mean(Rendimiento, na.rm = TRUE), .groups = "drop") %>%
  group_by(Nomcultivo) %>%
  summarise(
    rend_2003 = first(rend[Anio == 2003]),
    rend_2024 = first(rend[Anio == 2024]),
    n_anios   = 21,
    .groups   = "drop"
  ) %>%
  mutate(
    cagr_pct = round(((rend_2024 / rend_2003)^(1 / n_anios) - 1) * 100, 2)
  ) %>%
  filter(!is.na(cagr_pct)) %>%
  arrange(desc(cagr_pct))

View(cagr_rendimiento)

cagr_plot <- ggplot(cagr_rendimiento,
                    aes(x = reorder(Nomcultivo, cagr_pct),
                        y = cagr_pct,
                        fill = cagr_pct > 0)) +
  geom_col() +
  geom_text(aes(label = paste0(cagr_pct, "%")),
            hjust = ifelse(cagr_rendimiento$cagr_pct > 0, -0.1, 1.1), size = 3) +
  coord_flip() +
  geom_hline(yintercept = 0, color = "gray30") +
  scale_fill_manual(values = c("TRUE" = "#2d6a4f", "FALSE" = "#e63946"),
                    guide = "none") +
  labs(
    title    = "Tasa de Crecimiento Anual del Rendimiento 2003-2024 (CAGR)",
    subtitle = "Cultivos con CAGR positivo han mejorado su productividad por hectárea",
    x        = NULL,
    y        = "CAGR (%)"
  ) +
  theme_minimal(base_size = 12)

ggsave("cagr_rendimiento.png", cagr_plot, dpi = 300, width = 12, height = 8)


