  max_prod <- max(datos_cultivo$produccion, na.rm = TRUE)
  
  # 3. Cross join para que todos los estados aparezcan en cada año
  mapa_cultivo_i <- estados_sf %>%
    cross_join(tibble(Anio = anios)) %>%
    left_join(datos_cultivo, by = c("nom_join", "Anio"))
  
  # 4. Gráfica: un panel por año (facet_wrap por Anio)
  p <- ggplot(mapa_cultivo_i) +
    geom_sf(aes(fill = produccion), color = "white", linewidth = 0.15) +
    scale_fill_gradient(
      low      = "#d8f3dc",
      high     = "#1b4332",
      na.value = "gray92",
      name     = "Producción\n(ton)",
      labels   = comma,
      limits   = c(0, max_prod)     # escala fija para comparar años
    ) +
    facet_wrap(~ Anio, ncol = 6) +  # 6 columnas → 22 años en ~4 filas
    labs(
      title    = paste("Evolución Geográfica de la Producción —", cultivo_i),
      subtitle = "2003-2024 | Escala fija (máximo histórico del cultivo)",
      caption  = "Fuente: SIAP"
    ) +
    theme_void(base_size = 8) +
    theme(
      plot.title    = element_text(face = "bold", hjust = 0.5, size = 12),
      plot.subtitle = element_text(hjust = 0.5, color = "gray40", size = 9),
      strip.text    = element_text(face = "bold", size = 7),
      legend.position = "bottom"
    )
  
  # Limpiar nombre del cultivo para usarlo en el nombre de archivo
  nombre_limpio   <- gsub("[^a-zA-Z0-9]", "_", tolower(cultivo_i))
  nombre_archivo  <- sprintf("mapas_anuales/por_cultivo/evolucion_%s.png", nombre_limpio)
  ggsave(nombre_archivo, p, dpi = 120, width = 22, height = 16)
  message(sprintf("  Guardado: %s  [%s]", nombre_archivo, cultivo_i))
}

