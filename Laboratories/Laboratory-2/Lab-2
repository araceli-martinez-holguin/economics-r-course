# BRIEF: "Visualización geográfica de la producción de cada cultivo
#         por entidad federativa, usando el shapefile oficial de México."
#
# CONCEPTOS NUEVOS:
#   sf     → manejo de datos espaciales (geometrías de polígonos)
#   st_read()  → leer shapefiles (.shp)
#   geom_sf()  → capas geográficas en ggplot2
#   left_join()→ combinar datos tabulares con geometrías
# ==============================================================================

library(sf)       # simple features: estándar para datos espaciales en R
library(scales)   # formato de números en gráficas (comma, dollar, percent)
library(stringi)  # manipulación avanzada de cadenas de texto

# ------------------------------------------------------------------------------
# PREPARACIÓN: CARGAR Y ESTANDARIZAR EL SHAPEFILE
# ------------------------------------------------------------------------------

# st_read() lee el archivo de geometrías (.shp) junto con su tabla de atributos
# IMPORTANTE: los archivos .shp, .dbf, .shx y .prj deben estar en la misma carpeta
estados_sf <- st_read("00ent.shp")
glimpse(estados_sf)   # la columna "geometry" contiene los polígonos de cada estado

# ESTANDARIZACIÓN de nombres: quitar acentos + MAYÚSCULAS para hacer join sin errores
# stri_trans_general("Latin-ASCII") translitera ó→o, é→e, ñ→n, etc.
estados_sf <- estados_sf %>%
  mutate(
    nom_join = stri_trans_general(NOMGEO, "Latin-ASCII") %>%
      toupper() %>%
      trimws()   # eliminar espacios al inicio y final
  )

# Aplicar la misma transformación a los datos de cultivos
# NOTA: ajusta "Nomestado" si en tu base el nombre de columna es distinto (NomEdo, etc.)
data <- data %>%
  mutate(
    nom_join = stri_trans_general(Nomestado, "Latin-ASCII") %>%
      toupper() %>%
      trimws()
  )


# ------------------------------------------------------------------------------
# 6A — MAPA: PRODUCCIÓN TOTAL POR ESTADO (TODOS LOS CULTIVOS, 2024)
# ------------------------------------------------------------------------------

prod_estado_2024 <- data %>%
  filter(Anio == 2024) %>%
  group_by(nom_join) %>%
  summarise(
    produccion_total = sum(Volumenproduccion, na.rm = TRUE),
    valor_total      = sum(Valorproduccion,   na.rm = TRUE),
    .groups = "drop"
  )

# left_join pega los datos al shapefile para que cada polígono lleve su dato de producción
mapa_total <- estados_sf %>%
  left_join(prod_estado_2024, by = "nom_join")

mapa_prod_total <- ggplot(mapa_total) +
  geom_sf(aes(fill = produccion_total),     # fill = color interior del polígono
          color = "white", linewidth = 0.3) + # color = borde del polígono
  scale_fill_gradient(
    low      = "#d8f3dc",
    high     = "#1b4332",
    na.value = "gray90",       # estados sin dato → gris
    name     = "Producción\n(ton)",
    labels   = comma           # formatea números con comas: 1,000,000
  ) +
  labs(
    title    = "Producción Agrícola Total por Estado (2024)",
    subtitle = "Suma de todos los cultivos exportables",
    caption  = "Fuente: SIAP"
  ) +
  theme_void(base_size = 12) +    # theme_void elimina ejes, fondo gris, etc.
  theme(
    plot.title      = element_text(face = "bold", hjust = 0.5),
    plot.subtitle   = element_text(hjust = 0.5, color = "gray40"),
    legend.position = "right"
  )

ggsave("mapa_produccion_total_2024.png", mapa_prod_total, dpi = 300, width = 12, height = 8)


# ------------------------------------------------------------------------------
# 6B — MAPA: PRODUCCIÓN POR CULTIVO INDIVIDUAL (FACET por cultivo, año fijo)
