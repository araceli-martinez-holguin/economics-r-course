# 7D — BONUS: CREAR GIF ANIMADO con gganimate
# ─────────────────────────────────────────────────────────────────────────────
# gganimate extiende ggplot2 con la función transition_states() o transition_time()
# para animar una gráfica a lo largo de una variable (en nuestro caso, el año).
#
# Requiere: install.packages(c("gganimate", "gifski"))

# install.packages(c("gganimate", "gifski"))
library(gganimate)
library(gifski)

# Preparar datos para todos los años (sin loop — gganimate lo gestiona internamente)
datos_gif <- data %>%
  group_by(Anio, nom_join) %>%
  summarise(produccion_total = sum(Volumenproduccion, na.rm = TRUE), .groups = "drop")

mapa_gif_data <- estados_sf %>%
  cross_join(tibble(Anio = anios)) %>%
  left_join(datos_gif, by = c("nom_join", "Anio"))

# Construir la gráfica base (igual que 6A) y añadir transition_states()
gif_total <- ggplot(mapa_gif_data) +
  geom_sf(aes(fill = produccion_total), color = "white", linewidth = 0.3) +
  scale_fill_gradient(
    low      = "#d8f3dc",
    high     = "#1b4332",
    na.value = "gray90",
    name     = "Producción\n(ton)",
    labels   = comma
  ) +
  labs(
    title    = "Producción Agrícola Total por Estado — Año: {closest_state}",  # {closest_state} se actualiza automáticamente
    subtitle = "México 2003-2024 | Todos los cultivos exportables",
    caption  = "Fuente: SIAP"
  ) +
  theme_void(base_size = 12) +
  theme(
    plot.title      = element_text(face = "bold", hjust = 0.5),
    plot.subtitle   = element_text(hjust = 0.5, color = "gray40"),
    legend.position = "right"
  ) +
  # Clave de gganimate: transicionar entre estados (años)
  transition_states(Anio,
                    transition_length = 1,  # duración de la transición
                    state_length      = 2)  # duración de cada frame

# Renderizar y guardar el GIF
animate(gif_total,
        nframes  = length(anios) * 3,  # frames totales
        fps      = 4,                  # cuadros por segundo (menor = más lento)
        width    = 900,
        height   = 600,
        renderer = gifski_renderer("mapa_produccion_animado.gif"))

