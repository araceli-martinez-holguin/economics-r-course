# ==============================================================================
# SECCIÓN 7 — LOOPS: MAPAS ANIMADOS POR AÑO
# ==============================================================================
#
# CONCEPTO CLAVE — LOOP for:
#
#   Un loop "for" repite el mismo bloque de código cambiando solo una variable.
#   Estructura básica:
#
#     for (variable in vector_de_valores) {
#       # código que usa 'variable'
#     }
#
#   En nuestro caso: por cada año en la secuencia 2003-2024,
#   filtramos los datos, construimos el mapa y lo guardamos con un nombre único.
#
#   Esto reemplaza copiar y pegar el código 22 veces — principio DRY (Don't Repeat Yourself).
#
# SALIDA: una imagen PNG por año → se pueden combinar en GIF o video con gganimate
# ==============================================================================

# Crear carpeta de salida si no existe (dir.create es silencioso si ya existe)
dir.create("mapas_anuales",           showWarnings = FALSE)
dir.create("mapas_anuales/total",     showWarnings = FALSE)
dir.create("mapas_anuales/facet",     showWarnings = FALSE)
dir.create("mapas_anuales/estrella",  showWarnings = FALSE)


# ─────────────────────────────────────────────────────────────────────────────
# 7A — LOOP: MAPA TOTAL POR AÑO (producción de todos los cultivos)
# ─────────────────────────────────────────────────────────────────────────────

anios <- sort(unique(data$Anio))   # vector: 2003, 2004, ..., 2024

# Calcular escala fija para que todos los mapas sean comparables entre años
# (si usamos escala libre, un año con poca producción se verá igual de oscuro que uno alto)
rango_total <- data %>%
  group_by(Anio, nom_join) %>%
  summarise(prod = sum(Volumenproduccion, na.rm = TRUE), .groups = "drop") %>%
  summarise(min = min(prod, na.rm = TRUE), max = max(prod, na.rm = TRUE))

for (anio_i in anios) {
  
  # 1. Filtrar datos del año actual
  datos_anio <- data %>%
    filter(Anio == anio_i) %>%
    group_by(nom_join) %>%
    summarise(produccion_total = sum(Volumenproduccion, na.rm = TRUE), .groups = "drop")
  
  # 2. Unir con geometrías
  mapa_i <- estados_sf %>%
    left_join(datos_anio, by = "nom_join")
  
  # 3. Construir gráfica — misma estructura que 6A, pero con escala fija
  p <- ggplot(mapa_i) +
    geom_sf(aes(fill = produccion_total), color = "white", linewidth = 0.3) +
    scale_fill_gradient(
      low      = "#d8f3dc",
      high     = "#1b4332",
      na.value = "gray90",
      name     = "Producción\n(ton)",
      labels   = comma,
      limits   = c(rango_total$min, rango_total$max)   # ← escala fija
    ) +
    labs(
      title    = paste("Producción Agrícola Total por Estado —", anio_i),  # paste() añade el año al título
      subtitle = "Suma de todos los cultivos exportables | Escala fija 2003-2024",
      caption  = "Fuente: SIAP"
    ) +
    theme_void(base_size = 12) +
    theme(
      plot.title      = element_text(face = "bold", hjust = 0.5),
      plot.subtitle   = element_text(hjust = 0.5, color = "gray40"),
      legend.position = "right"
    )
  
  # 4. Guardar — sprintf formatea el número con ceros a la izquierda (2003, no 2003)
  nombre_archivo <- sprintf("mapas_anuales/total/mapa_total_%d.png", anio_i)
  ggsave(nombre_archivo, p, dpi = 150, width = 12, height = 8)
  
  # Imprimir progreso en consola
  message(sprintf("  Guardado: %s", nombre_archivo))
}

message("✅ Loop 7A completado: mapas anuales de producción total")


