# 8C — TOP 5 MUNICIPIOS POR CULTIVO (2024)
# Identificar los municipios más estratégicos para cada cultivo
# ------------------------------------------------------------------------------

top5_municipios <- data %>%
  filter(Anio == 2024) %>%
  group_by(Nomcultivo, NomMpio, NomEdo) %>%
  summarise(
    produccion = sum(Volumenproduccion, na.rm = TRUE),
    valor      = sum(Valorproduccion,   na.rm = TRUE),
    .groups    = "drop"
  ) %>%
  group_by(Nomcultivo) %>%
  slice_max(produccion, n = 5, with_ties = FALSE) %>%   # top 5 por producción
  mutate(rank = row_number()) %>%
  ungroup()

