message("✅ Loop 7B completado: mapas facet anuales por cultivo")


# ─────────────────────────────────────────────────────────────────────────────
# 7C — LOOP: MAPA POR CULTIVO INDIVIDUAL (iterar cultivos, todos los años en facet)
# ─────────────────────────────────────────────────────────────────────────────
# Gira la lógica: un archivo por CULTIVO, con un panel por año.
# Permite ver la evolución temporal del mapa de un solo cultivo.

dir.create("mapas_anuales/por_cultivo", showWarnings = FALSE)

cultivos_lista <- sort(unique(data$Nomcultivo))

for (cultivo_i in cultivos_lista) {
  
  # 1. Filtrar y preparar datos del cultivo para todos los años
  datos_cultivo <- data %>%
    filter(Nomcultivo == cultivo_i) %>%
    group_by(nom_join, Anio) %>%
    summarise(produccion = sum(Volumenproduccion, na.rm = TRUE), .groups = "drop")
  
